From 51c5da369bdfdca3e413296c8074824e6b01fd96 Mon Sep 17 00:00:00 2001
From: Jon Turney <jon.turney@dronecode.org.uk>
Date: Mon, 25 May 2026 18:57:35 +0100
Subject: [PATCH 1/2] cygwin: Only compute BFD_LIBS if building dumper

Don't try to determine BFD library link flags if we're not even building
dumper.

If we're using a bootstrap compiler, which can't link things,
AC_NO_EXECUTABLES will turn off AC_CHECK_LIB.
---
 winsup/configure.ac | 14 ++++++++------
 1 file changed, 8 insertions(+), 6 deletions(-)

diff --git a/winsup/configure.ac b/winsup/configure.ac
index 9b9b59dbc..12c1ce558 100644
--- a/winsup/configure.ac
+++ b/winsup/configure.ac
@@ -118,12 +118,14 @@ AC_ARG_ENABLE([dumper],
 
 AM_CONDITIONAL(BUILD_DUMPER, [test "x$build_dumper" = "xyes"])
 
-# libbfd.a doesn't have a pkgconfig file, so we guess what it's dependencies
-# are, based on what's present in the build environment
-BFD_LIBS="-lintl -liconv -liberty -lz"
-AC_CHECK_LIB([sframe], [sframe_decode], [BFD_LIBS="${BFD_LIBS} -lsframe"])
-AC_CHECK_LIB([zstd], [ZSTD_isError], [BFD_LIBS="${BFD_LIBS} -lzstd"])
-AC_SUBST([BFD_LIBS])
+if test "x$build_dumper" != "xno"; then
+  # libbfd.a doesn't have a pkgconfig file, so we guess what it's dependencies
+  # are, based on what's present in the build environment
+  BFD_LIBS="-lintl -liconv -liberty -lz"
+  AC_CHECK_LIB([sframe], [sframe_decode], [BFD_LIBS="${BFD_LIBS} -lsframe"])
+  AC_CHECK_LIB([zstd], [ZSTD_isError], [BFD_LIBS="${BFD_LIBS} -lzstd"])
+  AC_SUBST([BFD_LIBS])
+fi
 
 AC_CONFIG_FILES([
     Makefile
-- 
